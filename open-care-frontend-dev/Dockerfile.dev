# Use Node.js Alpine image
FROM node:22-alpine

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}

COPY package.json package-lock.json* ./

RUN npm install

COPY . .

COPY .env.dev .env

RUN npm run build

EXPOSE 5175

# CMD ["npm", "run", "dev", "--", "--host", "--port", "5175"]
CMD ["npm", "start"]
